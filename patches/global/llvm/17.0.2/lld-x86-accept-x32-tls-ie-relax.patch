From c8a4b7f2e5d1c9a3b6f8e0d7c4a2b9f1e6d3c8a7 Mon Sep 17 00:00:00 2001
From: Homura <egzozu.be.bas@gmail.com>
Date: Tue, 2 Jun 2026 00:00:00 +0300
Subject: [PATCH] [lld][ELF] Accept x32 GOTTPOFF TLS relaxations

The x32 ABI uses the x86-64 relocation namespace, but the compiler can
materialize TLS offsets with 32-bit register forms such as:

  movl foo@gottpoff(%rip), %eax
  addl foo@gottpoff(%rip), %eax

lld's R_X86_64_GOTTPOFF relaxation only recognizes the LP64 movq/addq
encodings. When building lld itself for x86_64-linux-muslx32, this makes
the final link fail with:

  R_X86_64_GOTTPOFF must be used in MOVQ or ADDQ instructions only

Handle the matching 32-bit encodings as well.

---

diff --git a/lld/ELF/Arch/X86_64.cpp b/lld/ELF/Arch/X86_64.cpp
index 349ccd2..a3d0b25 100644
--- a/lld/ELF/Arch/X86_64.cpp
+++ b/lld/ELF/Arch/X86_64.cpp
@@ -504,12 +504,26 @@ static void relaxTlsIeToLe(uint8_t *loc, const Relocation &, uint64_t val) {
   // because LEA with these registers needs 4 bytes to encode and thus
   // wouldn't fit the space.
 
-  if (memcmp(inst, "\x48\x03\x25", 3) == 0) {
+  if (memcmp(inst, "\x44\x03\x25", 3) == 0) {
+    // "addl foo@gottpoff(%rip),%r12d" -> "addl $foo,%r12d"
+    memcpy(inst, "\x41\x81\xc4", 3);
+  } else if (memcmp(inst, "\x48\x03\x25", 3) == 0) {
     // "addq foo@gottpoff(%rip),%rsp" -> "addq $foo,%rsp"
     memcpy(inst, "\x48\x81\xc4", 3);
   } else if (memcmp(inst, "\x4c\x03\x25", 3) == 0) {
     // "addq foo@gottpoff(%rip),%r12" -> "addq $foo,%r12"
     memcpy(inst, "\x49\x81\xc4", 3);
+  } else if (memcmp(loc - 2, "\x03\x25", 2) == 0) {
+    // "addl foo@gottpoff(%rip),%esp" -> "addl $foo,%esp"
+    memcpy(loc - 2, "\x81\xc4", 2);
+  } else if (memcmp(inst, "\x44\x03", 2) == 0) {
+    // "addl foo@gottpoff(%rip),%r[8-15]d" -> "leal foo(%r[8-15]),%r[8-15]d"
+    memcpy(inst, "\x45\x8d", 2);
+    *regSlot = 0x80 | (reg << 3) | reg;
+  } else if (memcmp(loc - 2, "\x03", 1) == 0) {
+    // "addl foo@gottpoff(%rip),%reg" -> "leal foo(%reg),%reg"
+    loc[-2] = 0x8d;
+    *regSlot = 0x80 | (reg << 3) | reg;
   } else if (memcmp(inst, "\x4c\x03", 2) == 0) {
     // "addq foo@gottpoff(%rip),%r[8-15]" -> "leaq foo(%r[8-15]),%r[8-15]"
     memcpy(inst, "\x4d\x8d", 2);
@@ -518,6 +532,14 @@ static void relaxTlsIeToLe(uint8_t *loc, const Relocation &, uint64_t val) {
     // "addq foo@gottpoff(%rip),%reg -> "leaq foo(%reg),%reg"
     memcpy(inst, "\x48\x8d", 2);
     *regSlot = 0x80 | (reg << 3) | reg;
+  } else if (memcmp(inst, "\x44\x8b", 2) == 0) {
+    // "movl foo@gottpoff(%rip),%r[8-15]d" -> "movl $foo,%r[8-15]d"
+    memcpy(inst, "\x41\xc7", 2);
+    *regSlot = 0xc0 | reg;
+  } else if (memcmp(loc - 2, "\x8b", 1) == 0) {
+    // "movl foo@gottpoff(%rip),%reg" -> "movl $foo,%reg"
+    loc[-2] = 0xc7;
+    *regSlot = 0xc0 | reg;
   } else if (memcmp(inst, "\x4c\x8b", 2) == 0) {
     // "movq foo@gottpoff(%rip),%r[8-15]" -> "movq $foo,%r[8-15]"
     memcpy(inst, "\x49\xc7", 2);
@@ -527,8 +549,8 @@ static void relaxTlsIeToLe(uint8_t *loc, const Relocation &, uint64_t val) {
     memcpy(inst, "\x48\xc7", 2);
     *regSlot = 0xc0 | reg;
   } else {
-    error(getErrorLocation(loc - 3) +
-          "R_X86_64_GOTTPOFF must be used in MOVQ or ADDQ instructions only");
+    error(getErrorLocation(loc - 2) +
+          "R_X86_64_GOTTPOFF must be used in MOVQ, ADDQ, MOVL or ADDL instructions only");
   }
 
   // The original code used a PC relative relocation.
